{
  "manifest_version": 3,
  "name": "ポモドーロ ご褒美タイマー 🍅",
  "version": "1.0",
  "description": "25分集中 → サイコロでご褒美決定！ゲーム感覚のポモドーロタイマー",
  "permissions": ["alarms", "notifications", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
